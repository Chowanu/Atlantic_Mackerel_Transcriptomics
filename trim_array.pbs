#!/bin/bash
#PBS -W group_list=pr_47002 -A pr_47002
#PBS -N trim
#PBS -o trim.log
#PBS -e trim.err
#PBS -m n

#PBS -l nodes=1:ppn=4
#PBS -l mem=16gb
#PBS -l walltime=12:00:00
### Run one job per line in the file list
#PBS -t 1-$(wc -l < forward_reads.txt)%20

cd $PBS_O_WORKDIR

# -------------------------
# Load environment
# -------------------------
module purge
module load tools
module load java/17-openjdk
module load trimmomatic/0.38

# -------------------------
# Output directory
# -------------------------
OUTDIR=/home/projects/pr_47002/data/DANIELA/mackerel/trimmed
mkdir -p "$OUTDIR"

# -------------------------
# Get forward read
# -------------------------
FWD=$(sed -n "${PBS_ARRAYID}p" forward_reads.txt)

# -------------------------
# Automatically derive reverse read
# -------------------------
REV=${FWD/_1.fq/_2.fq}

# -------------------------
# Extract basename (remove _1.fq)
# -------------------------
BASE=$(basename "$FWD" _1.fq)

echo "Processing $BASE"

trimmomatic PE -threads 4 -phred33 \
"$FWD" "$REV" \
"$OUTDIR/${BASE}_forward_paired.fq" \
"$OUTDIR/${BASE}_forward_unpaired.fq" \
"$OUTDIR/${BASE}_reverse_paired.fq" \
"$OUTDIR/${BASE}_reverse_unpaired.fq" \
SLIDINGWINDOW:4:15 MINLEN:36

