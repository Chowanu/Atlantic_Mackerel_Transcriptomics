# ------------------------------------------------------------
# 13. Extract GO IDs from PANTHER output for REVIGO
# ------------------------------------------------------------
# Run this after downloading PANTHER GO Biological Process results.
# PANTHER files should be saved as .txt files in the working directory.

make_revigo_go_only <- function(file_in, file_out) {
  
  panther <- read.table(
    file_in,
    sep = "\t",
    header = TRUE,
    skip = 11,
    fill = TRUE,
    quote = "",
    comment.char = ""
  )
  
  GO_ID <- gsub(
    ".*\\((GO:\\d+)\\).*",
    "\\1",
    panther[, 1]
  )
  
  FDR <- as.numeric(panther[, 8])
  
  GO_ID <- GO_ID[
    grepl("^GO:\\d+$", GO_ID) &
      !is.na(FDR) &
      FDR < 0.05
  ]
  
  write.table(
    GO_ID,
    file = file_out,
    quote = FALSE,
    row.names = FALSE,
    col.names = FALSE
  )
  
  cat(file_out, "saved with", length(GO_ID), "GO terms\n")
}

