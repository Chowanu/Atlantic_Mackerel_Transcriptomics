# ------------------------------------------------------------
# 10. DEG summary table
# ------------------------------------------------------------

count_DEGs <- function(res,
                       comparison_name,
                       padj_cutoff = 0.05,
                       log2fc_cutoff = 1) {
  
  res_df <- as.data.frame(res)
  res_df <- res_df[!is.na(res_df$padj), ]
  
  sig <- res_df[
    res_df$padj < padj_cutoff &
      abs(res_df$log2FoldChange) >= log2fc_cutoff,
  ]
  
  up <- sum(sig$log2FoldChange >= log2fc_cutoff)
  down <- sum(sig$log2FoldChange <= -log2fc_cutoff)
  
  data.frame(
    Comparison = comparison_name,
    Upregulated = up,
    Downregulated = down,
    Total_DEGs = up + down
  )
}

