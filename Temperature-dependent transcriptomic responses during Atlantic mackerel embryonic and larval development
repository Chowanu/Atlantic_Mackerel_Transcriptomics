# ------------------------------------------------------------
# 12. Create PANTHER gene lists
# ------------------------------------------------------------

make_panther_gene_list <- function(res,
                                   output_file,
                                   padj_cutoff = 0.05,
                                   log2fc_cutoff = 1) {
  
  res_df <- as.data.frame(res)
  res_df$gene_id <- rownames(res_df)
  
  sig <- res_df[
    !is.na(res_df$padj) &
      res_df$padj < padj_cutoff &
      abs(res_df$log2FoldChange) >= log2fc_cutoff,
  ]
  
  write.table(
    sig$gene_id,
    file = output_file,
    quote = FALSE,
    row.names = FALSE,
    col.names = FALSE
  )
  
  cat(output_file, "saved with", nrow(sig), "genes\n")
}

